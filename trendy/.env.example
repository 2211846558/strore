# عنوان الـ API (Laravel)
# للتطوير المحلي — يمر عبر proxy في vite.config.js (يتجنب مشاكل CORS):
VITE_API_BASE_URL=/api
# بديل مباشر للباكند:
# VITE_API_BASE_URL=http://localhost:8000/api

# مفتاح Stripe Publishable (نفس STRIPE_KEY في الباكند — يبدأ بـ pk_test_...)
VITE_STRIPE_PUBLISHABLE_KEY=

# في الإنتاج:
# VITE_API_BASE_URL=https://your-domain.com/api
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
